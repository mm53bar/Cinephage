{
	"name": "cinephage",
	"private": true,
	"version": "0.0.1",
	"license": "GPL-3.0-or-later",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node server.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"lint:fix": "prettier --write . && eslint . --fix",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"deps:audit": "npx --yes knip --dependencies --include dependencies,devDependencies --no-progress --reporter compact",
		"migrate:remove-enabled": "tsx scripts/remove-monitoring-enabled.ts",
		"auth:reset-admin-password": "node scripts/reset-admin-password.js",
		"fix:tv-subtitles": "node scripts/fix-tv-subtitle-paths.js",
		"library:backfill-release-metadata": "npx tsx scripts/backfill-release-metadata.ts",
		"library:export-release-metadata-audit": "npx tsx scripts/export-release-metadata-audit.ts",
		"db:reset": "rm -f data/cinephage.db && echo 'Database deleted. Will be recreated on next startup.'",
		"db:info": "sqlite3 data/cinephage.db \"SELECT value FROM settings WHERE key='schema_version'\" 2>/dev/null || echo 'No database found'"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@types/adm-zip": "^0.5.7",
		"@types/better-sqlite3": "^7.6.13",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25",
		"@types/parse-torrent": "^5.8.8",
		"daisyui": "^5.5.19",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"lucide-svelte": "^0.575.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"svelte": "^5.53.6",
		"svelte-check": "^4.4.4",
		"tailwindcss": "^4.1.14",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.18"
	},
	"overrides": {
		"cookie": "^0.7.0"
	},
	"optionalDependencies": {
		"@rollup/rollup-linux-arm64-gnu": "^4.59.0",
		"@rollup/rollup-linux-x64-gnu": "^4.59.0"
	},
	"dependencies": {
		"@better-auth/api-key": "^1.5.1",
		"adm-zip": "^0.5.16",
		"better-auth": "^1.5.1",
		"better-sqlite3": "^12.6.2",
		"camoufox-js": "^0.9.1",
		"cheerio": "^1.2.0",
		"chokidar": "^5.0.0",
		"domhandler": "^5.0.3",
		"fast-xml-parser": "^5.4.1",
		"fflate": "^0.8.2",
		"guessit-js": "^1.0.1",
		"iconv-lite": "^0.7.2",
		"js-yaml": "^4.1.1",
		"parse-torrent": "^11.0.19",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"playwright-core": "^1.58.2",
		"uuid": "^13.0.0",
		"zod": "^4.3.6"
	}
}
